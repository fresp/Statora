# Build stage
FROM golang:1.21-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Build worker
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/worker ./apps/worker

# Runtime stage
FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata iputils

COPY --from=builder /bin/worker /worker

CMD ["/worker"]
