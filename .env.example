# =========================
# Database
# =========================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=statusplatform

# =========================
# Redis
# =========================
REDIS_URI=localhost:6379

# =========================
# Security
# =========================
JWT_SECRET=change-this-jwt-secret
APP_ENCRYPTION_KEY=change-this-email-key-32-bytes!!
MFA_SECRET_KEY=change-this-mfa-key-32-bytes!!!!

# =========================
# Server
# =========================
PORT=8080
GRACEFUL_SHUTDOWN=true
SHUTDOWN_TIMEOUT=10

# =========================
# Default Admin (bootstrap only)
# =========================
ADMIN_EMAIL=admin@statusplatform.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# =========================
# Worker
# =========================
ENABLE_WORKER=true
